# -------------------------------------------------------------------------
# RS7_esport Platform - Global Production .gitignore
# -------------------------------------------------------------------------

# Android Studio / IntelliJ, VS Code, and Mac OS System Files
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store
Thumbs.db

# -------------------------------------------------------------------------
# Flutter & Dart Specific Files (Matches both User and Admin subfolders)
# -------------------------------------------------------------------------
**/build/
**/.dart_tool/
**/.packages
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/pubspec.lock

# Log and temporary files
*.log
*.crash
tmp/

# -------------------------------------------------------------------------
# CRITICAL SECURITY GUARDRAILS (Crucial for Hiding Secrets)
# -------------------------------------------------------------------------
# यह लाइन आपके Firebase की सीक्रेट कॉन्फ़िगरेशन फ़ाइल को GitHub पर जाने से रोकेगी
**/android/app/google-services.json

# Android keystores and signing credentials (जब आप ऐप को पब्लिश करेंगे)
**/android/*.keystore
**/android/*.jks
**/android/local.properties
**/android/key.properties
